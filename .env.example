# ---------------------------------------------------------------------------
# Copier ce fichier en `.env` et adapter les valeurs.
# Le `.env` réel n'est JAMAIS versionné (voir .gitignore) : il contient des secrets.
# ---------------------------------------------------------------------------

# --- Redpanda / Kafka ---
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092
TOPIC_RAW=air-quality-raw
TOPIC_ALERTS=air-quality-alerts

# --- Producer ---
SOURCE=simulated                # "simulated" (haute fréquence) ou "openmeteo" (données réelles)
PRODUCER_INTERVAL_SECONDS=2     # délai entre deux cycles de relevés
PRODUCER_N_STATIONS=5           # nombre de stations

# --- Snowflake (rempli à l'étape sink, laisser vide pour l'instant) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
